# Embedded DuckDB database file (built by `make seed`). Override to relocate it.
DUCKDB_PATH=../db/haulsim.duckdb

# Paths
OUTPUT_PATH=../output
# Gateway parser executable (full path to the file). The repo ships a cross-platform
# clone at ../executables/GWMReader.exe so the Import flow works without the Windows binary.
EXECUTE_FILE_PATH=../executables/GWMReader.exe
REFERENCE_DATA_PATH=../reference_data
# Temp directory for file processing (use short path like C:\Temp to avoid Windows MAX_PATH limit)
TEMP_DIR=
