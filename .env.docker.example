# Docker Compose settings — copy to ./.env (gitignored).
#
# No database credentials needed: the backend image bakes an embedded DuckDB file.
#
# Backend tunables surfaced into the container (M10). Defaults match the app's
# code defaults; keep MAX_UPLOAD_MB aligned with nginx client_max_body_size.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
MAX_UPLOAD_MB=5120
MAX_DECOMPRESSED_MB=20480
